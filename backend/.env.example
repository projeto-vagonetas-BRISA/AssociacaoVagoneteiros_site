# === Banco de Dados ===
DATABASE_URL="postgresql://USUARIO:SENHA@localhost:5432/vagoneteiros_db?schema=public"

# === Servidor ===
PORT=3000
FRONTEND_URL="http://localhost:5173"

# === Firebase Admin (notificações push) ===
FIREBASE_PROJECT_ID=vagoneteirosteste
FIREBASE_SERVICE_ACCOUNT_PATH=serviceAccountKey.json
# Ou via JSON direto (alternativa):
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# === Google Drive (galeria de fotos) ===
GOOGLE_APPLICATION_CREDENTIALS=secrets/seu-arquivo-service-account.json
GOOGLE_DRIVE_FOLDER_ID="id da pasta no Google Drive"

# === JWT (produção: obrigatório definir uma chave forte!) ===
# JWT_SECRET=minha-chave-secreta-aqui
