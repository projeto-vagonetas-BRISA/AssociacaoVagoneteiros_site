// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
model Usuario {
  id              Int      @id @default(autoincrement())
  name            String
  cpf             String   @unique
  historico       String?
  experiencia     String?  // tempo de experiência: "Menos de 1 ano", "1 a 3 anos", etc.
  email           String?  @unique
  telefone        String
  senha           String
  perfil          Perfil   @default(USUARIO)
  ativo           Boolean  @default(true)
  data_associacao DateTime @default(now())
  foto            Bytes?
  passeios        Passeio[]
  slotPasseios    SlotPasseio[]       @relation("UsuarioSlots")
  slotAtribuicoes SlotAtribuicao[]    @relation("VagoneteiroAtribuicoes")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

enum Perfil {
  USUARIO
  ADMIN
  REDATOR
}

model Passeio {
  id           Int           @id @default(autoincrement())
  usuarioId   Int
  usuario     Usuario       @relation(fields: [usuarioId], references: [id])
  preco        Decimal       @db.Decimal(10, 2)
  capacidade   Int
  data         DateTime
  horario      String        @default("08:00")
  ativo        Boolean       @default(true)
  agendamentos Agendamento[]
  avaliacoes   Avaliacao[]  
  createdAt    DateTime      @default(now())
}

model Clientes {
  id                 Int                 @id @default(autoincrement())
  nome               String
  cpf                String              @unique
  telefone           String
  email              String?             @unique
  agendamentos       Agendamento[]
  avaliacoes         Avaliacao[]
  pushSubscriptions  PushSubscription[]
  createdAt          DateTime            @default(now())
}

model Avaliacao {
  id         Int      @id @default(autoincrement())
  nota       Int
  comentario String
  clienteId  Int      
  cliente    Clientes @relation(fields: [clienteId], references: [id])
  passeioId  Int      
  passeio    Passeio  @relation(fields: [passeioId], references: [id])
  createdAt  DateTime @default(now())
}

model Agendamento {
  id                 Int                        @id @default(autoincrement())
  clienteId          Int
  cliente            Clientes                   @relation(fields: [clienteId], references: [id])
  passeioId          Int
  passeio            Passeio                    @relation(fields: [passeioId], references: [id])
  status             StatusAgendamento          @default(PENDENTE)
  promocao           Boolean                    @default(false)
  notificacao        Boolean                    @default(false)
  ciente             Boolean                    @default(false)
  acompanhantes       Int                        @default(0)
  notificacoes       NotificacaoAgendamento[]    
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt
}

model NotificacaoAgendamento {
  id                 Int                            @id @default(autoincrement())
  agendamentoId      Int
  agendamento        Agendamento                    @relation(fields: [agendamentoId], references: [id])
  pushSubscriptionId Int?
  pushSubscription   PushSubscription?             @relation(fields: [pushSubscriptionId], references: [id])
  tipo               TipoNotificacaoAgendamento
  enviarEm           DateTime
  createdAt          DateTime                       @default(now())
  updatedAt          DateTime                       @updatedAt
}

model PushSubscription {
  id            Int                 @id @default(autoincrement())
  clienteId     Int
  cliente       Clientes            @relation(fields: [clienteId], references: [id])
  token         String              @unique
  userAgent     String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  notificacoes  NotificacaoAgendamento[]
}

enum TipoNotificacaoAgendamento {
  ONE_WEEK
  THREE_DAYS
  ONE_DAY
  TWELVE_HOURS
  SIX_HOURS
  THREE_HOURS
  ONE_HOUR
  THIRTY_MINUTES
  TEN_MINUTES
}

enum StatusAgendamento {
  PENDENTE
  CONFIRMADO
  CANCELADO
  REMARCADO
}

// ─── NOVOS MODELOS: Sistema de Agendamento (Composite Pattern) ─────

enum TipoSlot {
  FIXO
  LOTE
  INDIVIDUAL
}

enum DiaSemana {
  SEGUNDA
  TERCA
  QUARTA
  QUINTA
  SEXTA
  SABADO
  DOMINGO
}

enum StatusSlot {
  DISPONIVEL
  ATRIBUIDO
  CANCELADO
  REALIZADO
}

enum StatusInstancia {
  AGENDADO
  EM_ANDAMENTO
  REALIZADO
  CANCELADO
}

enum StatusAtribuicao {
  ATRIBUIDO
  REALIZADO
  CANCELADO
}

model SlotPasseio {
  id             Int       @id @default(autoincrement())
  tipo           TipoSlot
  titulo         String
  descricao      String?

  // Horário
  horaInicio     String       // "08:00"
  horaFim        String       // "09:30"
  duracaoMinutos Int

  // Recorrência (FIXO)
  diaSemana      DiaSemana?
  dataInicio     DateTime?    // quando começa a valer
  dataFim        DateTime?    // quando termina (opcional)
  intervaloDias  Int?         // a cada N dias

  // Lote
  loteId         String?      // UUID pra agrupar slots do mesmo lote

  // Capacidade
  capacidade     Int          @default(1)
  valor          Decimal      @db.Decimal(10, 2)

  // Vagoneteiro fixo (opcional)
  usuarioId      Int?
  usuario        Usuario?     @relation("UsuarioSlots", fields: [usuarioId], references: [id])

  // Status
  status         StatusSlot   @default(DISPONIVEL)

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  instancias     SlotInstancia[]
  atribuicoes    SlotAtribuicao[]
}

model SlotInstancia {
  id             Int           @id @default(autoincrement())
  slotPasseioId  Int
  slotPasseio    SlotPasseio   @relation(fields: [slotPasseioId], references: [id], onDelete: Cascade)
  data           DateTime
  horaInicio     String
  horaFim        String
  status         StatusInstancia @default(AGENDADO)
  createdAt      DateTime      @default(now())

  atribuicoes    SlotAtribuicao[]

  @@unique([slotPasseioId, data, horaInicio])
}

model SlotAtribuicao {
  id              Int               @id @default(autoincrement())
  slotPasseioId   Int
  slotPasseio     SlotPasseio       @relation(fields: [slotPasseioId], references: [id], onDelete: Cascade)
  instanciaId     Int?
  instancia       SlotInstancia?    @relation(fields: [instanciaId], references: [id], onDelete: SetNull)
  vagoneteiroId   Int
  vagoneteiro     Usuario           @relation("VagoneteiroAtribuicoes", fields: [vagoneteiroId], references: [id])
  status          StatusAtribuicao  @default(ATRIBUIDO)
  atribuidoEm     DateTime          @default(now())
  canceladoEm     DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@unique([slotPasseioId, instanciaId, vagoneteiroId])
}